# ollama rm deepseek-r1-custom

# Define the base model we are customizing.
FROM deepseek-r1:8b

#  EXPLICITLY DEFINE ALL STOP TOKENS
# This is the primary fix for the runaway generation. We reinforce the model's
# default stop tokens from your `ollama show` output.
PARAMETER stop "<｜end▁of▁sentence｜>"
PARAMETER stop "<｜end of sentence｜>"
PARAMETER stop "<｜end_of_sentence｜>"
PARAMETER stop "<｜User｜>"
PARAMETER stop "<｜Assistant｜>"
PARAMETER stop "<｜begin▁of▁sentence｜>"
PARAMETER stop "<｜begin of sentence｜>"
PARAMETER stop "<｜begin_of_sentence｜>"
# Add a generic fallback stop token as a final safety measure.
PARAMETER stop "</s>"

# SET A HARD LIMIT ON RESPONSE LENGTH (SAFETY NET)
# This is a non-negotiable safety feature. The model WILL stop after 2048 tokens.
PARAMETER num_predict 2048

# SET THE CONTEXT WINDOW
# Crucial for your 12GB VRAM to prevent crashes.
PARAMETER num_ctx 8192

# PREVENT REPETITION
# This directly fights against the model "spewing nonsense" and getting stuck in loops.
PARAMETER repeat_penalty 1.15

# TUNE THE CREATIVITY
# We adjust the defaults slightly for more focused and less chaotic responses.
PARAMETER temperature 0.7
PARAMETER top_p 0.9

# --- HARDWARE UTILIZATION ---
PARAMETER num_gpu -1
